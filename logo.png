<svg width="400" height="400" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="400" height="400" fill="#667eea"/>
  
  <!-- Gradient definition -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background with gradient -->
  <rect width="400" height="400" fill="url(#grad1)"/>
  
  <!-- Shopping bag/cart shape -->
  <g transform="translate(100, 80)">
    <!-- Bag body -->
    <path d="M 50 20 L 60 60 Q 60 80 50 90 Q 40 80 40 60 Z" fill="white" opacity="0.9"/>
    <path d="M 150 20 L 140 60 Q 140 80 150 90 Q 160 80 160 60 Z" fill="white" opacity="0.9"/>
    <path d="M 60 60 L 140 60 L 145 90 L 55 90 Z" fill="white" opacity="0.9"/>
    
    <!-- Handle -->
    <path d="M 60 60 Q 100 20 140 60" stroke="white" stroke-width="8" fill="none" opacity="0.9"/>
  </g>
  
  <!-- Text "Market Andreia" -->
  <text x="200" y="280" font-family="Arial, sans-serif" font-size="56" font-weight="bold" fill="white" text-anchor="middle">Market Andreia</text>
  
  <!-- Tagline -->
  <text x="200" y="330" font-family="Arial, sans-serif" font-size="24" fill="white" text-anchor="middle" opacity="0.9">Suas Avaliações</text>
  
  <!-- Decorative stars -->
  <text x="80" y="360" font-size="36">⭐</text>
  <text x="320" y="360" font-size="36">⭐</text>
</svg>